# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# Cache Configuration
# Episode data + summaries are cached aggressively since they rarely change
# =============================================================================
# Default: 24 hours for episode data (86400 seconds)
CACHE_TTL_SECONDS=604800
# Note: Shows metadata is cached for 7 days (configured in constants.py)

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for generated API links (update for production)
API_BASE_URL=http://localhost:3000/

# =============================================================================
# LLM Configuration (Optional - for natural language episode queries)
# =============================================================================
# Enable LLM-powered natural language queries
LLM_ENABLED=false

# LLM API endpoint — any OpenAI-compatible base URL (OpenAI, Anthropic-via-router,
# self-hosted vLLM/Ollama/etc.). The default is a placeholder — set this to your
# own endpoint before enabling LLM_ENABLED.
LLM_API_URL=https://your-llm-endpoint.example/v1

# LLM API key (Bearer token sent in Authorization header)
LLM_API_KEY=your-api-key-here

# =============================================================================
# HTTP Configuration
# =============================================================================
# Timeout in seconds for external HTTP requests (epguides, TVMaze)
HTTP_TIMEOUT_SECONDS=5.0

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO
# Log output format: "json" for structured JSON (production), "text" for human-readable (dev)
LOG_FORMAT=json
LOG_REQUESTS=true
